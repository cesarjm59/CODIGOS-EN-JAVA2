import java.util.Scanner;
class ProbabilidadBinomialSencilla {
    public static void main(String[] args) {
        Scanner consola = new Scanner(System.in);

        System.out.print("Ingrese probabilidad de exito (p): ");
        double p = consola.nextDouble();

        System.out.print("Ingrese el numero total de ensayos (N): ");
        int N = consola.nextInt();

        double q = 1.0 - p;

        System.out.println("\nK\tProbabilidad P(K)");
        System.out.println("-------------------------");

        for (int K = 0; K <= N; K++) {
            double combinaciones = factorial(N) / (factorial(K) * factorial(N - K));
            double probExitos = Math.pow(p, K);
            double probFracasos = Math.pow(q, N - K);
            
            double resultado = combinaciones * probExitos * probFracasos;

            double resultadoCorto = Math.round(resultado * 10000.0) / 10000.0;

            System.out.println(K + "\t" + resultadoCorto);
        }
        consola.close();
    }
    public static double factorial(int numero) {
        double resultado = 1.0;
        for (int i = 2; i <= numero; i++) {
            resultado *= i;
        }
        return resultado;
    }
}
